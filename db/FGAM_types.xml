<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!--
    FGAM types.xml — add these entries to your server's db/types.xml (or merge via cfgeconomycore.xml)
    Adjust nominal/min/lifetime/restock to taste.
-->
<types>

    <!-- ══ FLARE GUN ══════════════════════════════════════════════════════════
         The flare gun is the VANILLA "Flaregun" class, which ships at nominal 0
         (never world-spawned). You CANNOT enable it from this separate file - the
         base mission db/types.xml already defines "Flaregun" and that definition
         wins, so a duplicate here is ignored.
         To make the gun spawn, edit the "Flaregun" entry in your mission's main
         db/types.xml directly, e.g.:
             <nominal>12</nominal>   <min>3</min>
         (its vanilla usage already covers Military/Police/Medic/Firefighter/Coast).
         That is why there is no Flaregun <type> below - only the flare cartridges. -->

    <!-- ══ FLARE ROUNDS ═══════════════════════════════════════════════════════
         NOTE: min is 0 on purpose. The flare round model is awkward for CE to place
         on surfaces (vanilla ships flares at nominal=0 for this reason). A non-zero
         min FORCES CE to keep re-placing them every loop, which floods the log with
         "is hard to place" / "exceeded max tests". min=0 lets CE fill toward nominal
         opportunistically without the relentless retries; nominals kept modest. -->
    <type name="FGAM_Mag_Red">
        <nominal>8</nominal>
        <lifetime>7200</lifetime>
        <restock>900</restock>
        <min>0</min>
        <quantmin>-1</quantmin>
        <quantmax>-1</quantmax>
        <cost>100</cost>
        <flags count_in_cargo="0" count_in_hoarder="0" count_in_map="1" count_in_player="0" crafted="0" deloot="0"/>
        <category name="weapons"/>
        <usage name="Military"/>
        <value name="Tier2"/>
        <value name="Tier3"/>
    </type>

