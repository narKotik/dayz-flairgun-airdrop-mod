<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!--
    FGAM types.xml — add these entries to your server's db/types.xml (or merge via cfgeconomycore.xml)
    Adjust nominal/min/lifetime/restock to taste.
-->
<types>

    <!-- ══ FLARE GUN ══════════════════════════════════════════════════════════
         The flare gun is the VANILLA "Flaregun" class, which ships at nominal 0
         (never world-spawned). You CANNOT enable it from this separate file - the
         base mission db/types.xml already defines "Flaregun" and that definition
         wins, so a duplicate here is ignored.
         To make the gun spawn, edit the "Flaregun" entry in your mission's main
         db/types.xml directly. That is why there is no Flaregun <type> below -
         only the flare ammo boxes/cartridges. -->

    <!-- ══ TIERED FLARE GUNS ══════════════════════════════════════════════════
         Three variants of the SAME gun (all inherit vanilla Flaregun via config).
         They differ only by spawn CONDITION (db/FGAM_spawnabletypes.xml <damage>)
         and loot tier (usage below). Combined with the per-shot wear, spawn
         condition = number of shots before the gun is ruined:
           Coast  -> Badly Damaged -> 1 use   (common, near spawn)
           Mid    -> Worn          -> 3 uses  (industrial / police)
           Mil    -> Pristine      -> 4 uses  (military, rarest)
         nominal/min are PER class; the map total is their SUM (~12 here).
         IMPORTANT: set the vanilla "Flaregun" to nominal 0 in the mission's base
         db/types.xml so only these variants world-spawn. -->

    <type name="FGAM_Flaregun_Coast">
        <nominal>6</nominal>
        <lifetime>14400</lifetime>
        <restock>0</restock>
        <min>3</min>
        <quantmin>-1</quantmin>
        <quantmax>-1</quantmax>
        <cost>100</cost>
        <flags count_in_cargo="0" count_in_hoarder="0" count_in_map="1" count_in_player="0" crafted="0" deloot="0"/>
        <category name="weapons"/>
        <usage name="Coast"/>
        <usage name="Village"/>
        <usage name="Town"/>
    </type>

    <type name="FGAM_Flaregun_Mid">
        <nominal>4</nominal>
        <lifetime>14400</lifetime>
        <restock>0</restock>
        <min>2</min>
        <quantmin>-1</quantmin>
        <quantmax>-1</quantmax>
        <cost>100</cost>
        <flags count_in_cargo="0" count_in_hoarder="0" count_in_map="1" count_in_player="0" crafted="0" deloot="0"/>
        <category name="weapons"/>
        <usage name="Industrial"/>
        <usage name="Police"/>
    </type>

    <type name="FGAM_Flaregun_Mil">
        <nominal>2</nominal>
        <lifetime>14400</lifetime>
        <restock>0</restock>
