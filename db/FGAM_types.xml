        <usage name="Military"/>
    </type>

    <!-- ══ FLARE AMMO BOXES ═══════════════════════════════════════════════════
         Ground loot (count_in_map="1"). These replace the magazines as the
         ground-spawn item - the magazines use vanilla's Flare_SingleRound.p3d,
         a thin rod-shaped model CE can't reliably place on the ground (confirmed
         via RPT "exceeded max tests" / "is hard to place"; the same reason
         Bohemia ships Ammo_Flare/Ammo_FlareRed/Blue/Green at nominal=0). The box
         uses the 00Buck_10RoundBox model instead (proven ground-spawnable - see
         AmmoBox_12gaSlug_10Rnd) and unpacks (right-click "Unbox") into ONE
         FGAM_Mag_<Color> pre-loaded with 3 rounds (config.cpp, CfgVehicles >
         FGAM_Box_FlareBase's Resources block - native Box_Base unpack action,
         no custom script). "usage" tags are OR'd together - a type matches ANY
         point tagged with one of its listed usages, so stacking multiple usage
         tags (mirrors vanilla Ammo_FlareRed/Blue/Green, which combine
         Military+Police+Medic+Firefighter+Coast) is how you avoid CE "exceeded
         max tests" starvation on a single narrow tag like Coast alone (only
         ~10 valid weapons+Coast points on all of Chernarus).

         Common tier (civilian): Green, Blue, White, Yellow, Orange
           -> Coast + Village + Town (large pool, easy to find near spawn/coast towns)
         Rare tier (military-grade): Red, Black
           -> Military + Industrial (matches heli crash / convoy secondary="InfectedArmy"
              and train wreck secondary="InfectedIndustrial" loot pools - no events.xml
              edits needed, those events pull from the general tagged CE pool by proximity) -->

    <type name="FGAM_Box_Red">
        <nominal>2</nominal>
        <lifetime>7200</lifetime>
        <restock>900</restock>
        <min>1</min>
        <quantmin>-1</quantmin>
